# InWallet Environment Variables Example
# Bu dosyayı .env olarak kopyalayın ve kendi anahtarlarınızı ekleyin.

# Yapay Zeka Servisleri için API Anahtarları
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here

# Veritabanı Ayarları (Docker kullanıyorsanız değiştirmeyin)
DB_USERNAME=user
DB_PASSWORD=password
DB_NAME=wallet_db

# JWT Ayarları (Opsiyonel)
JWT_SECRET=InWallet2026HackathonSecretKeyForJWTMustBe256BitsLong
